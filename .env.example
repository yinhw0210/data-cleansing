# =============================================================================
# 物流地址智能解析与补码 — 环境变量配置
# =============================================================================
# 使用方式：
#   1. 复制本文件为 .env ：  cp .env.example .env
#   2. 编辑 .env 填入真实 Key
#   3. 运行：                python main.py
#
# 所有路径默认为项目根目录下的相对路径，也可用绝对路径。
# =============================================================================


# =============================================================================
# LLM 大模型配置（OpenAI 兼容协议，支持一键切换厂商）
# =============================================================================
# 说明：
#   - 只需填写三项（BASE_URL / API_KEY / MODEL_NAME）即可切换模型
#   - OpenAI SDK 会自动追加 /v1 后缀，所以 BASE_URL 末尾不要加 /v1
#   - 以下列出主流厂商的 Base URL 供直接复制使用，取消注释即可

# --- DeepSeek（推荐，国内首选）---
#   快速模型: deepseek-v4-flash  1元/百万token入  2元/百万token出
#   强力模型: deepseek-v4-pro   3元/百万token入  6元/百万token出
#   旧名 deepseek-chat / deepseek-reasoner 将于 2026-07-24 弃用，请用新名
LLM_BASE_URL=https://api.deepseek.com

# --- 阿里云百炼（通义千问 Qwen）---
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus

# --- 智谱 AI（GLM）---
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL_NAME=glm-4-flash

# --- 字节豆包（Doubao）---
# LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# LLM_MODEL_NAME=doubao-1-5-pro-32k

# --- OpenAI（需代理）---
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL_NAME=gpt-4o-mini


# LLM API Key（必填！在对应厂商控制台创建）
LLM_API_KEY=your-api-key-here

# LLM 模型名称（需与上面 BASE_URL 对应厂商的模型名一致）
LLM_MODEL_NAME=deepseek-v4-flash

# LLM 温度（0.0=最稳定，推荐数据清洗场景；0.3~0.7=更有创造性）
# LLM_TEMPERATURE=0.0

# LLM 最大重试次数
# LLM_MAX_RETRIES=3


# =============================================================================
# 高德地图 API 配置
# =============================================================================
# 说明：
#   - 必须是「Web 服务」类型 Key，不能是 JS API 类型
#   - JS API Key 调用 REST API 会返回 USERKEY_PLAT_NOMATCH
#   - 创建地址：https://console.amap.com/dev/key/app
#   - 城市限定 0539 = 山东省临沂市（区号），留空 = 全国

AMAP_API_KEY=1a1a3665ce0986b49aa6be79cc42711d

# 高德城市限定码（0539 = 临沂市）
AMAP_CITY=0539

# 高德 API 最大重试次数
# AMAP_MAX_RETRIES=3


# =============================================================================
# 文件路径（默认使用 data/input/ 和 data/output/ 目录）
# =============================================================================
# 输入：待处理的运单 Excel（需包含「省市区街道」和「详细地址」列）
# INPUT_PATH=data/input/input.xlsx

# 输出：补码结果 Excel（保留所有原始列 + 追加结果列）
# OUTPUT_PATH=data/output/output.xlsx

# 片区围栏：WKT 多边形 JSON 数组
# AREAS_PATH=data/input/areas.json

# 日志目录：每次运行生成独立文件 pipeline_YYYY-MM-DD_HHMMSS.log
# LOGS_DIR=logs

# LLM System Prompt 模板（可随时编辑）
# PROMPT_TEMPLATE_PATH=prompt_template.txt


# =============================================================================
# 并发控制
# =============================================================================
# ThreadPoolExecutor 线程数
#   8  — 通用默认
#   16 — 网络延迟高时
#   1  — 调试时（避免并发日志混乱）
MAX_WORKERS=8
